# ADRA — example environment. Copy to `.env` (gitignored) and fill what you need.
# The engine runs OFFLINE with NO keys (the deterministic `mock` provider).
# NEVER commit a real .env — secrets live only in your own secret store / environment.

# --- LLM provider (OPTIONAL; the deterministic loop runs fully offline with NO key) ---
# Bring whatever you have — or run a local model for free. If ADRA_PROVIDER is unset, the
# first provider with a present key wins; otherwise the offline `mock` provider is used.
# ADRA_PROVIDER=                     # mock | anthropic | openai | groq | xai | mistral | deepseek | openrouter | together | ollama
# ADRA_MODEL=                        # optional; defaults per provider (e.g. gpt-4o, llama-3.3-70b-versatile)
# ADRA_TEMPERATURE=0.0
# ADRA_MAX_TOKENS=4096
#
# Per-role routing (orchestrate across providers in one run) — "provider:model" or "model":
# ADRA_MODEL_CRITIC=anthropic:claude-opus-4-8     # e.g. a strong model to critique/judge
# ADRA_MODEL_JUDGE=anthropic:claude-opus-4-8
# ADRA_MODEL_GENERATE=groq:llama-3.3-70b-versatile  # a cheaper/faster one to generate
#
# Put the key for whichever provider(s) you use (only the ones you pick are needed):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# TOGETHER_API_KEY=
#
# Local (free, offline-capable) via Ollama / LM Studio / vLLM — no key needed:
# ADRA_PROVIDER=ollama               # default endpoint http://localhost:11434/v1, model llama3.1
#
# Any other OpenAI-compatible endpoint:
# ADRA_BASE_URL=https://...          # + ADRA_API_KEY=...

# --- Adversarial loop ---
# ADRA_MAX_ROUNDS=3                  # generate -> critic -> revise iterations before escalation

# --- Active client governance suite (client-agnostic grounding) ---
# ADRA_CLIENT_DIR=                   # path to a client's standards/ suite (default: bundled Northwind)

# --- Safety: deterministic tools are read-only / dry-run unless explicitly enabled ---
# ADRA_ALLOW_EXTERNAL=0              # 1 = let tools actually call git / CI / the warehouse
# ADRA_REPO_PATH=                    # local git repo for the deterministic git/CI tools

# --- Connectors (Phase 3; BYO your own tokens locally — never stored by ADRA) ---
# GITHUB_TOKEN=                      # fine-grained PAT (PRs/issues/contents/checks) — BYOK
# AZURE_DEVOPS_PAT=
# DATABRICKS_HOST=
# DATABRICKS_TOKEN=
