# ADRA — example environment. Copy to `.env` (gitignored) and fill what you need.
# The engine runs OFFLINE with NO keys (the deterministic `mock` provider).
# NEVER commit a real .env — secrets live only in the CAOS_MANAGE vault.

# --- LLM provider (optional; adds the semantic layer on top of the deterministic floor) ---
# ADRA_PROVIDER=anthropic           # mock (default, offline) | anthropic
# ANTHROPIC_API_KEY=                 # required only when ADRA_PROVIDER=anthropic
# ADRA_MODEL=claude-opus-4-8
# ADRA_TEMPERATURE=0.0
# ADRA_MAX_TOKENS=4096

# --- Adversarial loop ---
# ADRA_MAX_ROUNDS=3                  # generate -> critic -> revise iterations before escalation

# --- Active client governance suite (client-agnostic grounding) ---
# ADRA_CLIENT_DIR=                   # path to a client's standards/ suite (default: bundled Northwind)

# --- Safety: deterministic tools are read-only / dry-run unless explicitly enabled ---
# ADRA_ALLOW_EXTERNAL=0              # 1 = let tools actually call git / CI / the warehouse
# ADRA_REPO_PATH=                    # local git repo for the deterministic git/CI tools

# --- Connectors (Phase 3; BYO your own tokens locally — never stored by ADRA) ---
# GITHUB_TOKEN=                      # fine-grained PAT (PRs/issues/contents/checks) — BYOK
# AZURE_DEVOPS_PAT=
# DATABRICKS_HOST=
# DATABRICKS_TOKEN=
